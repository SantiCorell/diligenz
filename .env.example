# Database (PostgreSQL)
# Prisma usa DATABASE_URL y DIRECT_URL. Dos opciones:
#
# --- LOCAL CON DOCKER (recomendado para desarrollo) ---
# 1. Ejecuta: docker compose up -d (o tu Postgres en otro puerto, ej. 5433)
# 2. Para Next.js en local: crea `.env.local` con DATABASE_URL y DIRECT_URL (Next prioriza .env.local sobre .env)
# 3. Migraciones con la misma DB: npm run db:migrate:local (usa dotenv-cli + .env.local)
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/diligenz"
# DIRECT_URL="postgresql://postgres:postgres@localhost:5432/diligenz"
#
# --- SUPABASE (producción o mismo DB remota) ---
# Supabase > Project Settings > Database > Connection string (URI)
# Session mode (6543) → DATABASE_URL (añade ?pgbouncer=true si no viene)
# Direct (5432) → DIRECT_URL. Sustituye [YOUR-PASSWORD] por la contraseña del proyecto.
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@...pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.PROJECT_REF:PASSWORD@...pooler.supabase.com:5432/postgres"
# Si usas solo variables de Supabase/Vercel, la app mapea POSTGRES_PRISMA_URL → DATABASE_URL y POSTGRES_URL_NON_POOLING → DIRECT_URL

# Node Environment
# En producción, Vercel lo configura automáticamente como "production"
NODE_ENV="development"

# NextAuth / Auth.js (inicio de sesión con Google, etc.)
# Secret: obligatorio. Genera con: openssl rand -base64 32
# La app usa AUTH_SECRET o, si no existe, NEXTAUTH_SECRET
AUTH_SECRET="tu-clave-secreta-super-segura-aqui"
# NEXTAUTH_SECRET="..."  # alternativa si no usas AUTH_SECRET
# URL de la app (Auth.js la usa para callbacks de OAuth)
# Local: http://localhost:3000   Producción: https://tu-dominio.com (sin barra final)
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (obligatorio para "Continuar con Google")
# Crear en: https://console.cloud.google.com/apis/credentials
# 1. Crear proyecto → APIs y servicios → Credenciales → Crear credenciales → ID de cliente OAuth 2.0
# 2. Tipo: Aplicación web
# 3. URIs de redirección autorizados (exactos, uno por línea):
#    http://localhost:3000/api/auth/callback/google
#    https://tu-dominio.com/api/auth/callback/google  (producción)
# 4. Copiar ID de cliente y Secret
GOOGLE_CLIENT_ID="tu-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="tu-google-client-secret"
# Alternativa compatible con Auth.js v5:
# AUTH_GOOGLE_ID="..."
# AUTH_GOOGLE_SECRET="..."  ← debe coincidir con el secreto del mismo cliente OAuth en Google Console

# Opcional: Acceso beta (hash bcrypt de la contraseña; si no se define, se usa la por defecto)
# BETA_ACCESS_HASH=""

# Opcional: URL pública de Google Drive para documentación del comprador (panel Mis documentos)
# NEXT_PUBLIC_BUYER_DOCUMENTS_DRIVE_URL="https://drive.google.com/drive/folders/..."
#
# Opcional: Google Drive del vendedor (panel Mis documentos vendedor)
# NEXT_PUBLIC_SELLER_DOCUMENTS_DRIVE_URL="https://drive.google.com/drive/folders/..."

# Correo automático — Zoho Mail (info@diligenz.es)
# Panel Zoho: Seguridad → Contraseñas de aplicación → genera una para "Diligenz web"
# España/UE: smtp.zoho.eu  |  Global: smtp.zoho.com
# SMTP_HOST="smtp.zoho.eu"
# SMTP_PORT=587
# SMTP_SECURE="false"
# SMTP_USER="info@diligenz.es"
# SMTP_PASS="contraseña-de-aplicación-de-zoho"
# SMTP_FROM="Diligenz <info@diligenz.es>"
# Copia interna al firmar mandato (por defecto info@diligenz.es)
# MANDATO_NOTIFY_EMAIL="info@diligenz.es"
# Probar: npm run email:test

# Google Drive — carpeta CLIENTES (crear carpeta por usuario y subir documentos)
# 1. Google Cloud → API Drive activada → cuenta de servicio → JSON con client_email y private_key
# 2. Compartir la carpeta CLIENTES con el email de la cuenta de servicio (Editor)
# 3. ID de la carpeta: https://drive.google.com/drive/folders/ESTE_ID
# GOOGLE_DRIVE_CLIENT_EMAIL="xxx@xxx.iam.gserviceaccount.com"
# GOOGLE_DRIVE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# GOOGLE_DRIVE_CLIENTS_FOLDER_ID="1tVJICwxeVheSxR0pDukGcIEKNt4FeHM5"
# Compartir carpeta del cliente con su email al registrarse (por defecto sí)
# GOOGLE_DRIVE_SHARE_WITH_CLIENT="true"
