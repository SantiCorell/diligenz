{
  "name": "diligenz",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && NODE_OPTIONS=--max-old-space-size=6144 next build",
    "build:with-migrate": "prisma generate && prisma migrate deploy && NODE_OPTIONS=--max-old-space-size=6144 next build",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:local": "npx --yes dotenv-cli@7 -e .env.local -- prisma migrate dev",
    "db:deploy:local": "npx --yes dotenv-cli@7 -e .env.local -- prisma migrate deploy",
    "db:seed:local-demo": "npx --yes dotenv-cli@7 -e .env.local -- node scripts/seed-local-demo-companies.mjs",
    "db:seed:local-demo:clean": "npx --yes dotenv-cli@7 -e .env.local -- node scripts/clean-local-demo-companies.mjs",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:push:local": "npx --yes dotenv-cli@7 -e .env.local -- prisma db push",
    "db:export-local": "node scripts/export-local-to-supabase.mjs",
    "db:studio": "prisma studio",
    "email:test": "npx --yes dotenv-cli@7 -e .env.local -- node scripts/test-smtp.mjs",
    "email:test:welcome": "npx --yes dotenv-cli@7 -e .env.local -- node scripts/test-welcome-email.mjs",
    "drive:test": "npx --yes dotenv-cli@7 -e .env.local -- node scripts/test-google-drive.mjs",
    "drive:oauth": "npx --yes dotenv-cli@7 -e .env.local -- node scripts/google-drive-oauth.mjs",
    "drive:sync-user": "npx --yes dotenv-cli@7 -e .env.local -- node scripts/sync-user-drive.mjs"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.7.2",
    "@prisma/client": "^6.19.2",
    "@vercel/speed-insights": "^1.0.0",
    "bcryptjs": "^3.0.3",
    "googleapis": "^173.0.0",
    "jszip": "^3.10.1",
    "lucide-react": "^0.563.0",
    "next": "16.1.4",
    "next-auth": "^5.0.0-beta.25",
    "nodemailer": "^7.0.13",
    "pdf-lib": "^1.17.1",
    "prisma": "^6.19.2",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.4",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
